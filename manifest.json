{
  "manifest_version": 3,
  "name": "OCR 單字學習",
  "version": "1.0.0",
  "description": "在網頁上拖曳選取英文單字，OCR 辨識後由 AI 產生中文翻譯、詞性與例句，並存成單字卡。",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "offscreen",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "OCR 單字學習",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options/options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "commands": {
    "start-ocr": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "啟用 OCR 選取模式"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/tesseract/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
